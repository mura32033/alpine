[{"data":1,"prerenderedAt":66},["Reactive",2],{"articles":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"cover":11,"date":12,"layout":13,"body":14,"_type":61,"_id":62,"_source":63,"_file":64,"_extension":65},"/articles/240227","articles",false,"","スウェーデンいってきた","10日くらいスウェーデンに行ってた。","/articles/2402271.jpg","2024/02/27","article",{"type":15,"children":16,"toc":58},"root",[17,24,29,34,39,44,53],{"type":18,"tag":19,"props":20,"children":21},"element","h1",{"id":9},[22],{"type":23,"value":9},"text",{"type":18,"tag":25,"props":26,"children":27},"p",{},[28],{"type":23,"value":10},{"type":18,"tag":25,"props":30,"children":31},{},[32],{"type":23,"value":33},"羽田から10時前発の便に乗って13時間ちょっと。なかなかに疲れる長旅だった。",{"type":18,"tag":25,"props":35,"children":36},{},[37],{"type":23,"value":38},"最初はコペンハーゲンに着いてそこから電車に乗ってスウェーデン入り。川の上を走って国境を越える。国が変わった感覚が皆無ですごく不思議な気持ちになった。少しずつ雪が見えてきて疲れているのにテンションが勝手に上がった。",{"type":18,"tag":25,"props":40,"children":41},{},[42],{"type":23,"value":43},"一応教授の研究の手伝いで行ってるから現地の大学で作業。日本の大学とは比較にならないくらいきれいでおしゃれなところだった。図書館がめちゃくちゃ羨ましい。カフェもコンビニもあって羨ましかった。",{"type":18,"tag":25,"props":45,"children":46},{},[47],{"type":18,"tag":48,"props":49,"children":52},"img",{"alt":50,"src":51},"2402272.jpg","/articles/2402272.jpg",[],{"type":18,"tag":25,"props":54,"children":55},{},[56],{"type":23,"value":57},"帰りもコペンハーゲンから羽田に12時間ちょっと。ほとんど寝てた。機内食にしては美味しかった。日本についてめちゃくちゃ安心した。やっぱり「母国」って大事なんだなあって感じた。",{"title":8,"searchDepth":59,"depth":59,"links":60},2,[],"markdown","content:articles:240227.md","content","articles/240227.md","md",1708962338039]